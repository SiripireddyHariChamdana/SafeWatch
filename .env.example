# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# Use PostgreSQL for production, or leave as-is to auto-fallback to SQLite
DATABASE_URL=postgresql://postgres:password@localhost:5432/safewatch

# ==========================================
# JWT & SECURITY
# ==========================================
SECRET_KEY=your-super-secret-key-change-in-production
TOKEN_EXPIRE_MINUTES=1440

# ==========================================
# CORS ALLOWED ORIGINS
# ==========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# ==========================================
# OPTIONAL: SMS NOTIFICATIONS (Twilio)
# Sign up free at: https://www.twilio.com/try-twilio
# Used for: Real SOS SMS to emergency contacts when btn-sos-trigger is pressed
# ==========================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1415xxxxxxx

# ==========================================
# OPTIONAL: EMAIL NOTIFICATIONS (Gmail SMTP)
# Use Gmail App Password (not your real password)
# Steps: Google Account → Security → 2FA → App Passwords → Create "SafeWatch"
# Used for: SOS email alert sent to operator's own email + emergency contacts
# ==========================================
GMAIL_USER=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
